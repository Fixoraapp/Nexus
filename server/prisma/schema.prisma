generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  username     String   @unique
  email        String   @unique
  passwordHash String
  avatar       String?
  bio          String?
  status       String   @default("online")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
